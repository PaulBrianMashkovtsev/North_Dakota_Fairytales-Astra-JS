---
import LandingLayout from "../layouts/LandingLayout.astro";
---

<LandingLayout>


<div class="wrap" role="main">
    <section class="badge" aria-labelledby="brand">
        <h1 id="brand" class="title">NORTH<br>DAKOTA<br>FAIRYTALES</h1>
        <p class="subtitle" aria-hidden="true">winter tales • books • songs</p>
    </section>

    <nav class="lang-stack" aria-label="Choose language">
        <a class="lang en" href="/en/">
            <span class="swatch" aria-hidden="true"></span>
            <span class="text">English</span>
        </a>
        <a class="lang es" href="/es/">
            <span class="swatch" aria-hidden="true"></span>
            <span class="text">Spanish (Español)</span>
        </a>
        <a class="lang ar" href="/ar/">
            <span class="swatch" aria-hidden="true"></span>
            <span class="text">Arabic (العربية)</span>
        </a>
        <a class="lang ru" href="/ru/">
            <span class="swatch" aria-hidden="true"></span>
            <span class="text">Russian (Русский)</span>
        </a>
        <a class="lang q" href="/index1">
            <span class="swatch" aria-hidden="true"></span>
            <span class="text"> . . . </span>
        </a>
    </nav>
</div>

<style>

     :root {
         --panel: #0f6aa1;
         --paper: #fff4cf;
         --ink: #222;
         --shadow: 0 12px 40px rgba(0,0,0,.35);
     }

    * { box-sizing: border-box; }

    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    body {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
        color: var(--ink);
        /* Фоновое изображение и оверлей */
        background:
                linear-gradient(180deg, rgba(0,0,0,.35), rgba(0,0,0,.55)),
                url('/img/forest.jpg') center/cover no-repeat fixed;
        display: grid;
        place-items: center;
    }


    /* Основной контейнер */
    .wrap {
        width: min(2400px, 96vw);
        height: min(1100px, 94vh);
        padding: clamp(16px, 3vw, 32px);
        display: grid;
        grid-template-columns: 1.05fr .95fr;
        gap: clamp(10px, 2vw, 20px);
        align-items: center;
        position: relative;
        z-index: 10;
    }

    /* Табличка с названием */
    .badge {
        background: rgba(15,106,161,.9);
        border: 4px solid rgba(0,0,0,.15);
        color: #fff;
        border-radius: 28px 32px 36px 30px / 26px 36px 30px 34px;
        box-shadow: var(--shadow);
        padding: clamp(28px, 4vw, 60px) clamp(36px, 5vw, 80px);
        transform: rotate(-6deg);
        max-width: 760px;
        margin-left: 120px;
    }

    .title {
        margin: 0 0 6px 0;
        font-size: clamp(48px, 7vw, 92px);
        letter-spacing: .04em;
        line-height: 1.05;
        font-weight: 800;
        color: #ffead0;
        text-shadow: 2px 2px 0 #b7332e, -2px 2px 0 #b7332e, 2px -2px 0 #b7332e, -2px -2px 0 #b7332e, 0 0 18px rgba(0,0,0,.35);
    }

    .subtitle {
        margin: 0;
        font-size: clamp(18px, 2.6vw, 26px);
        opacity: .9;
    }

    /* Список языков */
    .lang-stack {
        display: flex;
        flex-direction: column;
        gap: clamp(12px, 2.2vw, 18px);
        margin-left: 200px;
        margin-right: 450px;
    }

    .lang {
        --accent: #7dd3fc;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: var(--ink);
        background: var(--paper);
        padding: 20px 18px 20px 12px;
        border-radius: 10px;
        box-shadow: var(--shadow);
        border: 3px solid rgba(0,0,0,.09);
        min-width: 300px;
        font-weight: 700;
        transition: transform .18s ease, box-shadow .18s ease, translate .18s ease;
        outline: none;
    }

    .lang:hover { translate: 2px -2px; box-shadow: 0 16px 48px rgba(0,0,0,.45); }
    .lang:active, .lang.kick { transform: scale(1.06); }

    .swatch {
        width: 44px; height: 44px; border-radius: 8px;
        background: var(--accent);
        border: 3px solid rgba(0,0,0,.12);
        box-shadow: 0 10px 24px rgba(0,0,0,.25) inset;
    }

    .lang .text { font-size: clamp(18px, 2.6vw, 26px); }

    /* Цвета кнопок */
    .lang.es { --accent: #6f8c1d; }
    .lang.ar { --accent: rgb(238, 9, 9); }
    .lang.ru { --accent: rgb(237, 215, 22); }
    .lang.q { --accent: rgb(146, 20, 181); }

    @media (max-width: 860px) {
        .wrap { grid-template-columns: 1fr; height: auto; }
        .badge { margin: 8vh auto 0; transform: none; text-align: center; }
        .lang-stack { margin: 6vh auto 8vh; }
    }


</style>

</LandingLayout>