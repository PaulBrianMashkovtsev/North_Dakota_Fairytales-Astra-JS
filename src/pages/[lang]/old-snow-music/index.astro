        "@context": "https://schema.org",
        "@type": "VideoObject",
        name: currentSchema.name,
        description: currentSchema.description,
        embedUrl: currentVideoEmbedUrl,
        contentUrl: currentVideoId,
        thumbnailUrl: currentVideoThumbUrl,
        uploadDate: "2026-04-19",
        inLanguage: lang
    })}></script>

    <h2>{t.subtitle}</h2>

    <div class="intro-card">
        <p>{t.p0}</p>

        <p>{t.p1}</p>
        <div class="song-video-container">
