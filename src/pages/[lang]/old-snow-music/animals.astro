---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import musicIcon from "../../../components/icons_search_buttons/music_icon.jpg";
import { translations } from "../../../lib/i18n";
import {
    oldSnowContentLang,
    oldSnowHasFullSongHub,
    oldSnowHubStaticPaths,
    oldSnowWinterProgramJsonLd,
} from "../../../lib/oldSnowMusicHubLangs";

export function getStaticPaths() {
    return oldSnowHubStaticPaths();
}

const lang = Astro.params.lang;
const contentLang = oldSnowContentLang(lang);
const showOldSnowSongSearch = oldSnowHasFullSongHub(lang);
const i18nText = translations[lang as keyof typeof translations] || translations.en;
const snowyMusicAlt = (i18nText as any).snowyMusicAlt || "Snowy Music";
const searchAnimalsHref = `/${lang}/old-snow-music/search_animals/`;
const searchLabelByLang = {
    en: "Search",
    es: "Buscar",
    fr: "Recherche",
    ar: "بحث"
};
const searchLabel = searchLabelByLang[contentLang as keyof typeof searchLabelByLang] ?? searchLabelByLang.en;
const snowyMusicLabelByLang = {
    en: "Snowy Music",
    es: "Música Nevada",
    fr: "Musique de Neige",
    ar: "موسيقى ثلجية"
};
const snowyMusicLabel = snowyMusicLabelByLang[contentLang as keyof typeof snowyMusicLabelByLang] ?? snowyMusicLabelByLang.en;

const text = {
    en: {
        p1: "🐾 Animals in North Dakota",
        p2: "A Gentle World of Winter Creatures\n\nNorth Dakota is home to many animals that live quietly across its plains, forests, and snowy fields.\n\nFor children, these animals are not just part of nature — they become characters in stories, songs, and soft winter moments across the Great Plains wildlife landscape.",
        p3BeforeFox: "❄️ A Living Winter Landscape\n\nIn North Dakota, animals move through a calm and changing world of snow, wind, and light.\n\nChildren can imagine:\n\nred foxes walking lightly across fresh snow\n",
        p3AfterFoxBeforeOwl: "white-tailed deer and mule deer standing quietly under the winter sky\nsnowy owls watching from silent trees\n",
        p3AfterOwl: "ducks and snow geese resting near frozen lakes\nrabbits, mice, and squirrels moving gently through the cold\nbeavers building near icy water\ncoyotes calling softly across the plains\nprairie dogs — sometimes called \"barking squirrels\" — peeking out of the ground\npheasants crossing snowy fields\nand the great bison moving slowly in the distance\n\nThis natural world feels alive, but never overwhelming — steady, quiet, and easy to follow.",
        p4: "🌨 Animals in Stories and Songs\n\nIn North Dakota Fairytales, these animals appear in winter songs and stories for kids as friendly, simple characters.\n\nThey move slowly, observe, and help children understand the world through small, meaningful moments.\n\nA fox can represent warmth.\nAn owl can represent clarity.\nA bison can represent strength and calm.",
        p5: "🐾 A Calm Connection to Nature\n\nThis is what makes animals in North Dakota special for children.\n\nThey are part of a peaceful environment shaped by open lands and places like the National Grasslands, where animals live in balance with snow, sky, and seasons.\n\nThrough these animals, children experience:\n\ngentle storytelling\nemotional connection\nsimple and clear learning\na calm view of nature",
        p6: "🌲 A Different Way to See Animals\n\nInstead of fast or noisy content, North Dakota Fairytales offers a softer perspective.\n\nAnimals are not just something to learn about — they are something to feel, observe, and understand over time.\n\nIt also gently introduces ideas like winter survival for kids — how animals stay warm, find shelter, and move through the cold in calm and natural ways.",
        p7: "❄️ Discover the World of North Dakota Animals\n\nExplore songs and stories where winter animals come to life — slowly, gently, and in a way that children can truly connect with.",
    },
    es: {
        p1: "🐾 Animales en Dakota del Norte",
        p2: "Un mundo suave de criaturas de invierno\n\nDakota del Norte es hogar de muchos animales que viven en silencio a través de sus llanuras, bosques y campos nevados.\n\nPara los niños, estos animales no son solo parte de la naturaleza — se convierten en personajes de cuentos, canciones y momentos tranquilos de invierno dentro del paisaje de vida silvestre de las Grandes Llanuras.",
        p3BeforeFox: "❄️ Un paisaje invernal vivo\n\nEn Dakota del Norte, los animales se mueven en un mundo tranquilo y cambiante de nieve, viento y luz.\n\nLos niños pueden imaginar:\n\nzorros rojos caminando suavemente sobre la nieve fresca\n",
        p3AfterFoxBeforeOwl: "ciervos de cola blanca y ciervos mula en calma bajo el cielo de invierno\nbúhos nevados observando desde árboles silenciosos\n",
        p3AfterOwl: "patos y gansos de nieve descansando cerca de lagos congelados\nconejos, ratones y ardillas moviéndose suavemente en el frío\ncastores construyendo cerca del agua helada\ncoyotes llamando suavemente a través de las llanuras\nperritos de la pradera — a veces llamados \"ardillas que ladran\" — asomándose desde la tierra\nfaisanes cruzando campos nevados\ny los grandes bisontes moviéndose lentamente en la distancia\n\nEste mundo natural se siente vivo, pero nunca abrumador — constante, tranquilo y fácil de seguir.",
        p4: "🌨 Animales en cuentos y canciones\n\nEn North Dakota Fairytales, estos animales aparecen en canciones y cuentos de invierno para niños como personajes sencillos y amables.\n\nSe mueven despacio, observan y ayudan a los niños a entender el mundo a través de pequeños momentos con significado.\n\nUn zorro puede representar el calor.\nUn búho puede representar la claridad.\nUn bisonte puede representar la fuerza y la calma.",
        p5: "🐾 Una conexión tranquila con la naturaleza\n\nEsto es lo que hace especiales a los animales de Dakota del Norte para los niños.\n\nForman parte de un entorno pacífico, moldeado por tierras abiertas y lugares como las National Grasslands, donde los animales viven en equilibrio con la nieve, el cielo y las estaciones.\n\nA través de estos animales, los niños experimentan:\n\nnarración suave\nconexión emocional\naprendizaje simple y claro\nuna visión tranquila de la naturaleza",
        p6: "🌲 Una forma diferente de ver a los animales\n\nEn lugar de contenido rápido o ruidoso, North Dakota Fairytales ofrece una perspectiva más suave.\n\nLos animales no son solo algo que aprender — son algo que sentir, observar y comprender con el tiempo.\n\nTambién introduce suavemente ideas como la supervivencia en invierno para niños — cómo los animales se mantienen calientes, encuentran refugio y se mueven en el frío de forma natural y tranquila.",
        p7: "❄️ Descubre el mundo de los animales de Dakota del Norte\n\nExplora canciones y cuentos donde los animales de invierno cobran vida — lentamente, con suavidad y de una forma con la que los niños pueden conectar de verdad.",
    },
    fr: {
        p1: "🐾 Animaux du Dakota du Nord",
        p2: "Un monde doux de créatures d'hiver\n\nLe Dakota du Nord abrite de nombreux animaux qui vivent paisiblement à travers ses plaines, ses forêts et ses champs enneigés.\n\nPour les enfants, ces animaux ne sont pas seulement une partie de la nature — ils deviennent des personnages dans des histoires, des chansons et de doux moments d'hiver au cœur des Grandes Plaines.",
        p3BeforeFox: "❄️ Un paysage hivernal vivant\n\nDans le Dakota du Nord, les animaux évoluent dans un monde calme et changeant de neige, de vent et de lumière.\n\nLes enfants peuvent imaginer :\n\ndes renards roux marchant doucement sur la neige fraîche\n",
        p3AfterFoxBeforeOwl: "des cerfs de Virginie et des cerfs mulets immobiles sous le ciel d'hiver\ndes hiboux des neiges observant depuis des arbres silencieux\n",
        p3AfterOwl: "des canards et des oies des neiges reposant près des lacs gelés\ndes lapins, des souris et des écureuils se déplaçant doucement dans le froid\ndes castors construisant près de l'eau glacée\ndes coyotes appelant doucement à travers les plaines\ndes chiens de prairie — parfois appelés « écureuils qui aboient » — sortant de leurs terriers\ndes faisans traversant les champs enneigés\net les grands bisons avançant lentement au loin\n\nCe monde naturel semble vivant, mais jamais écrasant — stable, paisible et facile à suivre.",
        p4: "🌨 Animaux dans les histoires et les chansons\n\nDans North Dakota Fairytales, ces animaux apparaissent dans des chansons et des histoires d'hiver pour enfants comme des personnages simples et bienveillants.\n\nIls avancent lentement, observent et aident les enfants à comprendre le monde à travers de petits moments pleins de sens.\n\nUn renard peut représenter la chaleur.\nUn hibou peut représenter la clarté.\nUn bison peut représenter la force et le calme.",
        p5: "🐾 Un lien apaisant avec la nature\n\nC'est ce qui rend les animaux du Dakota du Nord si particuliers pour les enfants.\n\nIls font partie d'un environnement paisible, façonné par de vastes espaces ouverts et des lieux comme les National Grasslands, où les animaux vivent en équilibre avec la neige, le ciel et les saisons.\n\nÀ travers ces animaux, les enfants découvrent :\n\nune narration douce\nune connexion émotionnelle\nun apprentissage simple et clair\nune vision calme de la nature",
        p6: "🌲 Une autre manière de voir les animaux\n\nAu lieu d'un contenu rapide ou bruyant, North Dakota Fairytales propose une approche plus douce.\n\nLes animaux ne sont pas seulement quelque chose à apprendre — ils sont quelque chose à ressentir, à observer et à comprendre avec le temps.\n\nCela introduit aussi doucement des idées comme la survie en hiver pour les enfants — comment les animaux restent au chaud, trouvent un abri et se déplacent dans le froid de manière naturelle et tranquille.",
        p7: "❄️ Découvrez le monde des animaux du Dakota du Nord\n\nExplorez des chansons et des histoires où les animaux d'hiver prennent vie — lentement, en douceur, et d'une manière à laquelle les enfants peuvent vraiment se connecter.",
    },
    ar: {
        p1: "🐾 الحيوانات في داكوتا الشمالية",
        p2: "عالم لطيف من مخلوقات الشتاء\n\nتُعد داكوتا الشمالية موطنًا للعديد من الحيوانات التي تعيش بهدوء عبر السهول والغابات والحقول المغطاة بالثلوج.\n\nبالنسبة للأطفال، هذه الحيوانات ليست مجرد جزء من الطبيعة — بل تصبح شخصيات في القصص والأغاني ولحظات الشتاء الهادئة عبر طبيعة السهول الكبرى.",
        p3BeforeFox: "❄️ مشهد شتوي حي\n\nفي داكوتا الشمالية، تتحرك الحيوانات في عالم هادئ ومتغير من الثلج والرياح والضوء.\n\nيمكن للأطفال أن يتخيلوا:\n\nثعالب حمراء تمشي بخفة فوق الثلج الطازج\n",
        p3AfterFoxBeforeOwl: "غزلان بيضاء الذيل وغزلان المول تقف بهدوء تحت سماء الشتاء\nبوم ثلجي يراقب من الأشجار الصامتة\n",
        p3AfterOwl: "بط وإوز ثلجي يستريح قرب البحيرات المتجمدة\nأرانب وفئران وسناجب تتحرك بلطف في البرد\nقنادس تبني بالقرب من المياه المتجمدة\nذئاب البراري تنادي بهدوء عبر السهول\nكلاب البراري — التي تُسمى أحيانًا \"سناجب نباحة\" — تخرج من الأرض\nطيور الدراج تعبر الحقول المغطاة بالثلوج\nوالبيسون العظيم يتحرك ببطء في الأفق\n\nيبدو هذا العالم الطبيعي حيًا، لكنه لا يكون مزدحمًا أو مربكًا — بل ثابت وهادئ وسهل المتابعة.",
        p4: "🌨 الحيوانات في القصص والأغاني\n\nفي مشروع North Dakota Fairytales، تظهر هذه الحيوانات في الأغاني والقصص الشتوية للأطفال كشخصيات بسيطة ولطيفة.\n\nتتحرك ببطء، تراقب، وتساعد الأطفال على فهم العالم من خلال لحظات صغيرة ذات معنى.\n\nيمكن للثعلب أن يرمز إلى الدفء.\nيمكن للبومة أن ترمز إلى الوضوح.\nيمكن للبيسون أن يرمز إلى القوة والهدوء.",
        p5: "🐾 ارتباط هادئ مع الطبيعة\n\nهذا ما يجعل الحيوانات في داكوتا الشمالية مميزة للأطفال.\n\nفهي جزء من بيئة هادئة تشكلها الأراضي الواسعة وأماكن مثل المراعي الوطنية، حيث تعيش الحيوانات في توازن مع الثلج والسماء والفصول.\n\nمن خلال هذه الحيوانات، يختبر الأطفال:\n\nسردًا هادئًا ولطيفًا\nارتباطًا عاطفيًا بالطبيعة\nتعلمًا بسيطًا وواضحًا\nنظرة هادئة إلى العالم الطبيعي",
        p6: "🌲 طريقة مختلفة لرؤية الحيوانات\n\nبدلًا من المحتوى السريع أو الصاخب، يقدم North Dakota Fairytales منظورًا أكثر هدوءًا.\n\nالحيوانات ليست فقط شيئًا للتعلم — بل شيئًا يمكن الشعور به وملاحظته وفهمه مع الوقت.\n\nكما يقدم بلطف أفكارًا مثل كيفية بقاء الحيوانات في الشتاء للأطفال — كيف تحافظ على الدفء، وتجد المأوى، وتتحرك في البرد بطريقة طبيعية وهادئة.",
        p7: "❄️ اكتشف عالم حيوانات داكوتا الشمالية\n\nاستكشف الأغاني والقصص حيث تنبض الحيوانات الشتوية بالحياة — ببطء وهدوء وبطريقة يمكن للأطفال أن يرتبطوا بها حقًا.",
    },
    ru: {
        p1: "🐾 Животные Северной Дакоты",
        p2: "Мягкий мир зимних существ\n\nСеверная Дакота — дом для множества животных, которые спокойно живут на её равнинах, в лесах и заснеженных полях. Для детей эти животные — не просто часть природы, а герои историй, песен и тихих зимних моментов среди природы Великих равнин.",
        p3BeforeFox:
            "❄️ Живой зимний пейзаж\n\nВ Северной Дакоте животные движутся в спокойном и постоянно меняющемся мире снега, ветра и света. Дети могут представить: рыжих лис, легко идущих по свежему снегу,\n",
        p3AfterFoxBeforeOwl:
            "белохвостых и чернохвостых оленей, спокойно стоящих под зимним небом, снежных сов, наблюдающих с тихих деревьев,\n",
        p3AfterOwl:
            "уток и снежных гусей у замёрзших озёр, кроликов, мышей и белок, мягко передвигающихся в холоде, бобров у ледяной воды, койотов, тихо перекликающихся на равнинах, луговых собачек — которых иногда называют «лающими белками» — выглядывающих из земли, фазанов, переходящих заснеженные поля, и великих бизонов, медленно идущих вдали.\n\nЭтот природный мир ощущается живым, но никогда не перегружает — он устойчивый, тихий и понятный.",
        p4: "🌨 Животные в сказках и песнях\n\nВ North Dakota Fairytales эти животные появляются в зимних песнях и историях для детей как дружелюбные и простые персонажи. Они двигаются медленно, наблюдают и помогают детям понимать мир через небольшие, но важные моменты.\nЛиса может символизировать тепло.\nСова — ясность.\nБизон — силу и спокойствие.",
        p5: "🐾 Спокойная связь с природой\n\nИменно это делает животных Северной Дакоты особенными для детей. Они являются частью мирной среды открытых земель, включая Национальные травяные равнины, где животные живут в гармонии со снегом, небом и сезонами.\nЧерез этих животных дети получают:\n\nмягкие истории\nэмоциональную связь\nпростое и понятное обучение\nспокойный взгляд на природу",
        p6: "🌲 Другой взгляд на животных\n\nВместо быстрого и шумного контента North Dakota Fairytales предлагает более мягкую перспективу. Животные — это не только то, о чём нужно узнавать, но и то, что можно чувствовать, наблюдать и постепенно понимать.\nТакже мягко вводится тема выживания зимой для детей — как животные сохраняют тепло, находят укрытие и живут в холоде естественно и спокойно.",
        p7: "❄️ Откройте мир животных Северной Дакоты\n\nИсследуйте песни и истории, где зимние животные оживают — медленно, мягко и так, чтобы дети могли по-настоящему почувствовать с ними связь.",
    },
    ur: {
        p1: "🐾 نارتھ ڈکوٹا کے جانور",
        p2: "سردیوں کی مخلوقات کی نرم دنیا\n\nNorth Dakota بہت سے جانوروں کا گھر ہے جو اس کی میدانوں، جنگلات اور برف سے ڈھکے کھیتوں میں خاموشی سے رہتے ہیں۔ بچوں کے لیے یہ جانور صرف فطرت کا حصہ نہیں ہوتے بلکہ کہانیوں، گانوں اور نرم سردیوں کے لمحات کے کردار بن جاتے ہیں۔",
        p3BeforeFox:
            "❄️ زندہ سردیوں کا منظر\n\nنارتھ ڈکوٹا میں جانور برف، ہوا اور روشنی کی ایک پرسکون اور بدلتی ہوئی دنیا میں حرکت کرتے ہیں۔ بچے تصور کر سکتے ہیں: سرخ لومڑیاں جو تازہ برف پر ہلکے قدموں سے چلتی ہیں،\n",
        p3AfterFoxBeforeOwl:
            "سفید دم والے اور مول ہرن جو خاموشی سے سرد آسمان کے نیچے کھڑے ہیں، برفیلی اُلو جو خاموش درختوں سے دیکھ رہے ہیں،\n",
        p3AfterOwl:
            "بطخیں اور برفیلی ہنس جو جمے ہوئے جھیلوں کے پاس آرام کر رہے ہیں، خرگوش، چوہے اور گلہریاں جو نرمی سے سردی میں حرکت کرتی ہیں، بیور جو برفیلے پانی کے پاس گھر بناتے ہیں، کویوٹے جو میدانوں میں آہستہ آواز دیتے ہیں، پریری ڈاگز — جنہیں کبھی کبھی \"بھونکنے والی گلہریاں\" کہا جاتا ہے — زمین سے جھانکتے ہیں، تیتر برفیلے میدانوں کو عبور کرتے ہیں، اور عظیم بائسن جو دور آہستہ چلتے ہیں۔\n\nیہ قدرتی دنیا زندہ محسوس ہوتی ہے مگر کبھی بھاری نہیں لگتی — یہ متوازن، خاموش اور آسانی سے سمجھ آنے والی ہے۔",
        p4: "🌨 کہانیوں اور گانوں میں جانور\n\nNorth Dakota Fairytales میں یہ جانور بچوں کے لیے سردیوں کے گانوں اور کہانیوں میں دوستانہ اور سادہ کرداروں کے طور پر ظاہر ہوتے ہیں۔ وہ آہستہ چلتے ہیں، مشاہدہ کرتے ہیں اور بچوں کو چھوٹے مگر معنی خیز لمحات کے ذریعے دنیا کو سمجھنے میں مدد دیتے ہیں۔\nلومڑی گرمی کی علامت ہو سکتی ہے۔\nاُلو وضاحت کی علامت ہے۔\nبائسن طاقت اور سکون کی علامت ہے۔",
        p5: "🐾 فطرت سے پُرسکون تعلق\n\nیہی چیز نارتھ ڈکوٹا کے جانوروں کو بچوں کے لیے خاص بناتی ہے۔ وہ ایک پُرامن ماحول کا حصہ ہیں جو کھلی زمینوں اور نیشنل گراس لینڈز جیسے مقامات پر مشتمل ہے، جہاں جانور برف، آسمان اور موسموں کے ساتھ توازن میں رہتے ہیں۔\nان جانوروں کے ذریعے بچے حاصل کرتے ہیں:\n\nنرم کہانیاں\nجذباتی تعلق\nسادہ اور واضح سیکھنا\nفطرت کا پُرسکون منظر",
        p6: "🌲 جانوروں کو دیکھنے کا ایک مختلف طریقہ\n\nتیز یا شور والے مواد کے بجائے، North Dakota Fairytales ایک نرم نقطۂ نظر پیش کرتا ہے۔ جانور صرف سیکھنے کی چیز نہیں بلکہ محسوس کرنے، دیکھنے اور وقت کے ساتھ سمجھنے کی چیز ہیں۔\nیہ بچوں کو نرمی سے یہ بھی سکھاتا ہے کہ سردیوں میں جانور کیسے زندہ رہتے ہیں — کیسے وہ خود کو گرم رکھتے ہیں، پناہ ڈھونڈتے ہیں اور قدرتی انداز میں سردی میں حرکت کرتے ہیں۔",
        p7: "❄️ نارتھ ڈکوٹا کے جانوروں کی دنیا دریافت کریں\n\nان گانوں اور کہانیوں کو دریافت کریں جہاں سردیوں کے جانور زندگی پاتے ہیں — آہستہ، نرمی سے، اور ایسے انداز میں جس سے بچے واقعی جُڑ سکیں۔",
    },
    hi: {
        p1: "🐾 नॉर्थ डकोटा के जानवर",
        p2: "सर्दियों के जीवों की एक शांत दुनिया\n\nNorth Dakota कई जानवरों का घर है, जो इसके मैदानों, जंगलों और बर्फ से ढके खेतों में शांति से रहते हैं। बच्चों के लिए ये जानवर केवल प्रकृति का हिस्सा नहीं हैं — वे कहानियों, गीतों और कोमल सर्दियों के पलों के पात्र बन जाते हैं।",
        p3BeforeFox:
            "❄️ जीवित सर्दियों का दृश्य\n\nनॉर्थ डकोटा में जानवर बर्फ, हवा और रोशनी की शांत और बदलती दुनिया में चलते हैं। बच्चे कल्पना कर सकते हैं: लाल लोमड़ियाँ जो ताज़ी बर्फ पर हल्के कदमों से चलती हैं,\n",
        p3AfterFoxBeforeOwl:
            "सफेद-पूंछ वाले और म्यूल हिरण जो सर्द आकाश के नीचे शांत खड़े हैं, बर्फीले उल्लू जो शांत पेड़ों से देख रहे हैं,\n",
        p3AfterOwl:
            "बतख और बर्फीले हंस जो जमी हुई झीलों के पास आराम कर रहे हैं, खरगोश, चूहे और गिलहरियाँ जो धीरे-धीरे ठंड में चलती हैं, बीवर जो बर्फीले पानी के पास घर बनाते हैं, कोयोट जो मैदानों में धीमी आवाज़ में पुकारते हैं, प्रेयरी डॉग — जिन्हें कभी-कभी \"भौंकने वाली गिलहरियाँ\" कहा जाता है — ज़मीन से झांकते हैं, तीतर जो बर्फीले खेतों को पार करते हैं, और महान बाइसन जो दूर धीरे-धीरे चलते हैं।\n\nयह प्राकृतिक दुनिया जीवित महसूस होती है, लेकिन कभी भारी नहीं लगती — यह स्थिर, शांत और समझने में आसान है।",
        p4: "🌨 कहानियों और गीतों में जानवर\n\nNorth Dakota Fairytales में ये जानवर बच्चों के लिए सर्दियों के गीतों और कहानियों में दोस्ताना और सरल पात्रों के रूप में दिखाई देते हैं। वे धीरे चलते हैं, देखते हैं और बच्चों को छोटे लेकिन अर्थपूर्ण पलों के माध्यम से दुनिया को समझने में मदद करते हैं।\nलोमड़ी गर्माहट का प्रतीक हो सकती है।\nउल्लू स्पष्टता का प्रतीक है।\nबाइसन ताकत और शांति का प्रतीक है।",
        p5: "🐾 प्रकृति से एक शांत संबंध\n\nयही कारण है कि नॉर्थ डकोटा के जानवर बच्चों के लिए खास हैं। वे खुले मैदानों और नेशनल ग्रासलैंड्स जैसे स्थानों के शांत वातावरण का हिस्सा हैं, जहाँ जानवर बर्फ, आकाश और मौसमों के साथ संतुलन में रहते हैं।\nइन जानवरों के माध्यम से बच्चे अनुभव करते हैं:\n\nकोमल कहानी कहना\nभावनात्मक जुड़ाव\nसरल और स्पष्ट सीखना\nप्रकृति का शांत दृष्टिकोण",
        p6: "🌲 जानवरों को देखने का एक अलग तरीका\n\nतेज़ या शोर वाले कंटेंट के बजाय, North Dakota Fairytales एक नरम दृष्टिकोण प्रदान करता है। जानवर केवल सीखने की चीज़ नहीं हैं — वे महसूस करने, देखने और समय के साथ समझने की चीज़ हैं।\nयह बच्चों को धीरे-धीरे यह भी सिखाता है कि जानवर सर्दियों में कैसे जीवित रहते हैं — वे कैसे गर्म रहते हैं, आश्रय ढूंढते हैं और ठंड में प्राकृतिक रूप से चलते हैं।",
        p7: "❄️ नॉर्थ डकोटा के जानवरों की दुनिया खोजें\n\nउन गीतों और कहानियों का अन्वेषण करें जहाँ सर्दियों के जानवर जीवंत हो जाते हैं — धीरे, कोमलता से, और इस तरह कि बच्चे वास्तव में उनसे जुड़ सकें।",
    },
    bn: {
        p1: "🐾 নর্থ ডাকোটার প্রাণী",
        p2: "শীতের প্রাণীদের একটি কোমল জগৎ\n\nNorth Dakota বহু প্রাণীর আবাসস্থল, যারা এর সমভূমি, বন এবং তুষারে ঢাকা মাঠে শান্তভাবে বসবাস করে। শিশুদের জন্য এই প্রাণীরা শুধু প্রকৃতির অংশ নয় — তারা গল্প, গান এবং নরম শীতের মুহূর্তের চরিত্র হয়ে ওঠে।",
        p3BeforeFox:
            "❄️ একটি জীবন্ত শীতের দৃশ্য\n\nনর্থ ডাকোটায় প্রাণীরা তুষার, বাতাস এবং আলোর শান্ত ও পরিবর্তনশীল জগতে চলাফেরা করে। শিশুরা কল্পনা করতে পারে: লাল শিয়াল যারা নতুন তুষারের ওপর হালকা পায়ে হাঁটে,\n",
        p3AfterFoxBeforeOwl:
            "সাদা-লেজ এবং মিউল হরিণ যারা শীতের আকাশের নিচে শান্তভাবে দাঁড়িয়ে থাকে, তুষার পেঁচা যারা নীরব গাছ থেকে দেখছে,\n",
        p3AfterOwl:
            "হাঁস এবং তুষার রাজহাঁস যারা জমাট বাঁধা হ্রদের পাশে বিশ্রাম নিচ্ছে, খরগোশ, ইঁদুর এবং কাঠবিড়ালি যারা ঠান্ডায় ধীরে ধীরে চলাফেরা করে, বিবার যারা বরফের জলের কাছে ঘর বানায়, কায়োট যারা সমভূমিতে আস্তে ডাকে, প্রেইরি ডগ — যাদের কখনও \"ঘেউ-ঘেউ করা কাঠবিড়ালি\" বলা হয় — মাটি থেকে উঁকি দেয়, ফেজান্ট যারা তুষার ঢাকা মাঠ পার হয়, এবং দূরে ধীরে চলা বিশাল বাইসন।\n\nএই প্রাকৃতিক জগৎ জীবন্ত মনে হয়, কিন্তু কখনোই ভারী নয় — এটি স্থির, শান্ত এবং সহজে বোঝা যায়।",
        p4: "🌨 গল্প ও গানে প্রাণীরা\n\nNorth Dakota Fairytales-এ এই প্রাণীরা শিশুদের জন্য শীতের গান ও গল্পে বন্ধুসুলভ এবং সহজ চরিত্র হিসেবে উপস্থিত হয়। তারা ধীরে চলে, পর্যবেক্ষণ করে এবং ছোট কিন্তু অর্থপূর্ণ মুহূর্তের মাধ্যমে শিশুদের পৃথিবী বুঝতে সাহায্য করে।\nশিয়াল উষ্ণতার প্রতীক হতে পারে।\nপেঁচা স্বচ্ছতার প্রতীক।\nবাইসন শক্তি ও শান্তির প্রতীক।",
        p5: "🐾 প্রকৃতির সঙ্গে শান্ত সংযোগ\n\nএই কারণেই নর্থ ডাকোটার প্রাণীরা শিশুদের জন্য বিশেষ। তারা খোলা ভূমি এবং ন্যাশনাল গ্রাসল্যান্ডসের মতো স্থানের শান্ত পরিবেশের অংশ, যেখানে প্রাণীরা তুষার, আকাশ এবং ঋতুর সঙ্গে ভারসাম্যে থাকে।\nএই প্রাণীদের মাধ্যমে শিশুরা পায়:\n\nকোমল গল্প বলা\nআবেগের সংযোগ\nসহজ ও পরিষ্কার শেখা\nপ্রকৃতির শান্ত দৃষ্টিভঙ্গি",
        p6: "🌲 প্রাণীদের দেখার একটি ভিন্ন উপায়\n\nদ্রুত বা শব্দপূর্ণ কন্টেন্টের পরিবর্তে, North Dakota Fairytales একটি নরম দৃষ্টিভঙ্গি দেয়। প্রাণীরা শুধু শেখার বিষয় নয় — তারা অনুভব করার, দেখার এবং সময়ের সঙ্গে বোঝার বিষয়।\nএটি শিশুদের ধীরে ধীরে শেখায় শীতে প্রাণীরা কীভাবে বেঁচে থাকে — কীভাবে তারা উষ্ণ থাকে, আশ্রয় খুঁজে পায় এবং ঠান্ডায় স্বাভাবিকভাবে চলে।",
        p7: "❄️ নর্থ ডাকোটার প্রাণীদের জগৎ আবিষ্কার করুন\n\nসেই গান ও গল্পগুলো অন্বেষণ করুন যেখানে শীতের প্রাণীরা জীবন্ত হয়ে ওঠে — ধীরে, কোমলভাবে, এবং এমনভাবে যাতে শিশুরা সত্যিই তাদের সঙ্গে সংযোগ করতে পারে।",
    },
    fa: {
        p1: "🐾 حیوانات داکوتای شمالی",
        p2: "دنیایی آرام از موجودات زمستانی\n\nNorth Dakota خانه‌ی بسیاری از حیوانات است که در دشت‌ها، جنگل‌ها و زمین‌های پوشیده از برف آن به‌آرامی زندگی می‌کنند. برای کودکان، این حیوانات فقط بخشی از طبیعت نیستند — بلکه به شخصیت‌های داستان‌ها، ترانه‌ها و لحظات آرام زمستانی تبدیل می‌شوند.",
        p3BeforeFox:
            "❄️ چشم‌انداز زنده‌ی زمستانی\n\nدر داکوتای شمالی، حیوانات در دنیایی آرام و در حال تغییر از برف، باد و نور حرکت می‌کنند. کودکان می‌توانند تصور کنند: روباه‌های سرخ که به‌آرامی روی برف تازه راه می‌روند،\n",
        p3AfterFoxBeforeOwl:
            "گوزن‌های دم‌سفید و مول که زیر آسمان زمستانی بی‌صدا ایستاده‌اند، جغدهای برفی که از درختان ساکت نظاره می‌کنند،\n",
        p3AfterOwl:
            "اردک‌ها و غازهای برفی که کنار دریاچه‌های یخ‌زده استراحت می‌کنند، خرگوش‌ها، موش‌ها و سنجاب‌ها که به‌آرامی در سرما حرکت می‌کنند، بیورها که کنار آب یخی خانه می‌سازند، کایوت‌ها که در دشت‌ها آرام صدا می‌زنند، سگ‌های دشتی — که گاهی «سنجاب‌های پارس‌کننده» نامیده می‌شوند — از زمین سرک می‌کشند، قرقاول‌ها که از میان مزارع برفی عبور می‌کنند، و بایسون‌های بزرگ که در دوردست آهسته حرکت می‌کنند.\n\nاین دنیای طبیعی زنده به نظر می‌رسد، اما هرگز سنگین یا شلوغ نیست — آرام، پایدار و قابل درک است.",
        p4: "🌨 حیوانات در داستان‌ها و ترانه‌ها\n\nدر North Dakota Fairytales این حیوانات در ترانه‌ها و داستان‌های زمستانی برای کودکان به‌عنوان شخصیت‌های ساده و دوستانه ظاهر می‌شوند. آن‌ها آرام حرکت می‌کنند، مشاهده می‌کنند و به کودکان کمک می‌کنند جهان را از طریق لحظات کوچک اما معنادار درک کنند.\nروباه می‌تواند نماد گرما باشد.\nجغد نماد وضوح است.\nبایسون نماد قدرت و آرامش است.",
        p5: "🐾 ارتباطی آرام با طبیعت\n\nاین همان چیزی است که حیوانات داکوتای شمالی را برای کودکان خاص می‌کند. آن‌ها بخشی از محیطی آرام در سرزمین‌های باز و مکان‌هایی مانند چمنزارهای ملی هستند، جایی که حیوانات در تعادل با برف، آسمان و فصل‌ها زندگی می‌کنند.\nاز طریق این حیوانات، کودکان تجربه می‌کنند:\n\nداستان‌گویی ملایم\nارتباط احساسی\nیادگیری ساده و روشن\nنگاه آرام به طبیعت",
        p6: "🌲 نگاهی متفاوت به حیوانات\n\nبه‌جای محتوای سریع و پرسر و صدا، North Dakota Fairytales دیدگاهی نرم‌تر ارائه می‌دهد. حیوانات فقط چیزی برای یاد گرفتن نیستند — بلکه چیزی برای احساس کردن، مشاهده و درک تدریجی هستند.\nهمچنین به‌آرامی مفاهیمی مانند بقا در زمستان را معرفی می‌کند — اینکه حیوانات چگونه گرم می‌مانند، پناه پیدا می‌کنند و به‌طور طبیعی در سرما حرکت می‌کنند.",
        p7: "❄️ دنیای حیوانات داکوتای شمالی را کشف کنید\n\nترانه‌ها و داستان‌هایی را کشف کنید که در آن‌ها حیوانات زمستانی زنده می‌شوند — آرام، ملایم و به شکلی که کودکان واقعاً با آن‌ها ارتباط برقرار کنند.",
    },
    pt: {
        p1: "🐾 Animais de Dakota do Norte",
        p2: "Um mundo gentil de criaturas de inverno\n\nNorth Dakota é o lar de muitos animais que vivem tranquilamente em suas planícies, florestas e campos cobertos de neve. Para as crianças, esses animais não são apenas parte da natureza — eles se tornam personagens de histórias, canções e momentos suaves de inverno.",
        p3BeforeFox:
            "❄️ Uma paisagem de inverno viva\n\nEm Dakota do Norte, os animais se movem em um mundo calmo e em constante mudança de neve, vento e luz. As crianças podem imaginar: raposas vermelhas caminhando suavemente sobre a neve fresca,\n",
        p3AfterFoxBeforeOwl:
            "veados-de-cauda-branca e veados-mula parados em silêncio sob o céu de inverno, corujas-das-neves observando de árvores silenciosas,\n",
        p3AfterOwl:
            "patos e gansos-da-neve descansando perto de lagos congelados, coelhos, ratos e esquilos movendo-se gentilmente no frio, castores construindo perto de águas geladas, coiotes chamando suavemente pelas planícies, cães-da-pradaria — às vezes chamados de \"esquilos que latem\" — espiando para fora da terra, faisões atravessando campos nevados e os grandes bisões movendo-se lentamente ao longe.\n\nEsse mundo natural parece vivo, mas nunca é excessivo — é estável, silencioso e fácil de acompanhar.",
        p4: "🌨 Animais em histórias e canções\n\nEm North Dakota Fairytales, esses animais aparecem em canções e histórias de inverno para crianças como personagens amigáveis e simples. Eles se movem devagar, observam e ajudam as crianças a entender o mundo por meio de pequenos momentos significativos.\nA raposa pode representar calor.\nA coruja pode representar clareza.\nO bisão pode representar força e calma.",
        p5: "🐾 Uma conexão tranquila com a natureza\n\nÉ isso que torna os animais de Dakota do Norte especiais para as crianças. Eles fazem parte de um ambiente pacífico de terras abertas e lugares como as pradarias nacionais, onde vivem em equilíbrio com a neve, o céu e as estações.\nPor meio desses animais, as crianças experimentam:\n\nnarrativas suaves\nconexão emocional\naprendizado simples e claro\numa visão tranquila da natureza",
        p6: "🌲 Uma forma diferente de ver os animais\n\nEm vez de conteúdo rápido e barulhento, North Dakota Fairytales oferece uma perspectiva mais suave. Os animais não são apenas algo para aprender — são algo para sentir, observar e entender com o tempo.\nTambém introduz gentilmente ideias como a sobrevivência no inverno — como os animais se mantêm aquecidos, encontram abrigo e se movem no frio de maneira natural.",
        p7: "❄️ Descubra o mundo dos animais de Dakota do Norte\n\nExplore canções e histórias onde os animais de inverno ganham vida — devagar, gentilmente, e de uma forma que as crianças possam realmente se conectar.",
    },
    ms: {
        p1: "🐾 Haiwan di North Dakota",
        p2: "Dunia lembut makhluk musim sejuk\n\nNorth Dakota adalah rumah kepada banyak haiwan yang hidup dengan tenang di padang rumput, hutan, dan kawasan bersalji. Bagi kanak-kanak, haiwan ini bukan sekadar sebahagian daripada alam — mereka menjadi watak dalam cerita, lagu, dan detik musim sejuk yang lembut.",
        p3BeforeFox:
            "❄️ Landskap musim sejuk yang hidup\n\nDi North Dakota, haiwan bergerak dalam dunia salji, angin dan cahaya yang tenang dan sentiasa berubah. Kanak-kanak boleh membayangkan: rubah merah berjalan perlahan di atas salji segar,\n",
        p3AfterFoxBeforeOwl:
            "rusa ekor putih dan rusa mule berdiri dengan tenang di bawah langit musim sejuk, burung hantu salji memerhati dari pokok yang sunyi,\n",
        p3AfterOwl:
            "itik dan angsa salji berehat berhampiran tasik beku, arnab, tikus dan tupai bergerak perlahan dalam kesejukan, memerang membina di tepi air berais, koyot memanggil dengan lembut di padang, anjing prairie — kadang-kadang dipanggil \"tupai menyalak\" — mengintai dari tanah, burung pegar melintasi padang bersalji, dan bison besar bergerak perlahan di kejauhan.\n\nDunia semula jadi ini terasa hidup, tetapi tidak pernah membebankan — stabil, tenang dan mudah diikuti.",
        p4: "🌨 Haiwan dalam cerita dan lagu\n\nDalam North Dakota Fairytales, haiwan ini muncul dalam lagu dan cerita musim sejuk untuk kanak-kanak sebagai watak yang mesra dan ringkas. Mereka bergerak perlahan, memerhati, dan membantu kanak-kanak memahami dunia melalui detik kecil yang bermakna.\nRubah melambangkan kehangatan.\nBurung hantu melambangkan kejelasan.\nBison melambangkan kekuatan dan ketenangan.",
        p5: "🐾 Hubungan tenang dengan alam\n\nInilah yang menjadikan haiwan di North Dakota istimewa untuk kanak-kanak. Mereka adalah sebahagian daripada persekitaran yang damai di tanah terbuka dan kawasan seperti padang rumput nasional, di mana haiwan hidup seimbang dengan salji, langit dan musim.\nMelalui haiwan ini, kanak-kanak mengalami:\n\ncerita yang lembut\nhubungan emosi\npembelajaran yang mudah dan jelas\npandangan alam yang tenang",
        p6: "🌲 Cara berbeza melihat haiwan\n\nBerbanding kandungan yang laju dan bising, North Dakota Fairytales menawarkan perspektif yang lebih lembut. Haiwan bukan sekadar untuk dipelajari — tetapi untuk dirasai, diperhatikan dan difahami dari masa ke masa.\nIa juga memperkenalkan secara lembut idea seperti kelangsungan hidup musim sejuk — bagaimana haiwan kekal hangat, mencari perlindungan dan bergerak dalam kesejukan secara semula jadi.",
        p7: "❄️ Terokai dunia haiwan North Dakota\n\nTerokai lagu dan cerita di mana haiwan musim sejuk menjadi hidup — perlahan, lembut, dan dengan cara yang benar-benar dekat dengan kanak-kanak.",
    },
    id: {
        p1: "🐾 Hewan di North Dakota",
        p2: "Dunia lembut makhluk musim dingin\n\nNorth Dakota adalah rumah bagi banyak hewan yang hidup dengan tenang di padang rumput, hutan, dan wilayah bersalju. Bagi anak-anak, hewan-hewan ini bukan sekadar bagian dari alam — mereka menjadi tokoh dalam cerita, lagu, dan momen musim dingin yang lembut.",
        p3BeforeFox:
            "❄️ Lanskap musim dingin yang hidup\n\nDi North Dakota, hewan bergerak dalam dunia salju, angin, dan cahaya yang tenang dan terus berubah. Anak-anak dapat membayangkan: rubah merah berjalan ringan di atas salju segar,\n",
        p3AfterFoxBeforeOwl:
            "rusa ekor putih dan rusa mule berdiri tenang di bawah langit musim dingin, burung hantu salju mengamati dari pohon yang sunyi,\n",
        p3AfterOwl:
            "bebek dan angsa salju beristirahat di dekat danau beku, kelinci, tikus, dan tupai bergerak perlahan dalam dingin, berang-berang membangun di dekat air es, koyote bersuara lembut di padang, anjing prairie — kadang disebut \"tupai menggonggong\" — mengintip dari tanah, burung pegar melintasi ladang bersalju, dan bison besar bergerak perlahan di kejauhan.\n\nDunia alam ini terasa hidup, namun tidak pernah berlebihan — stabil, tenang, dan mudah dipahami.",
        p4: "🌨 Hewan dalam cerita dan lagu\n\nDalam North Dakota Fairytales, hewan-hewan ini muncul dalam lagu dan cerita musim dingin sebagai karakter yang ramah dan sederhana. Mereka bergerak perlahan, mengamati, dan membantu anak-anak memahami dunia melalui momen kecil yang bermakna.\nRubah melambangkan kehangatan.\nBurung hantu melambangkan kejernihan.\nBison melambangkan kekuatan dan ketenangan.",
        p5: "🐾 Koneksi tenang dengan alam\n\nInilah yang membuat hewan di North Dakota istimewa bagi anak-anak. Mereka adalah bagian dari lingkungan damai di tanah terbuka dan padang rumput nasional, tempat hewan hidup seimbang dengan salju, langit, dan musim.\nMelalui hewan-hewan ini, anak-anak merasakan:\n\ncerita yang lembut\nhubungan emosional\npembelajaran yang sederhana dan jelas\npandangan alam yang tenang",
        p6: "🌲 Cara berbeda melihat hewan\n\nAlih-alih konten yang cepat dan bising, North Dakota Fairytales menawarkan perspektif yang lebih lembut. Hewan bukan hanya untuk dipelajari — tetapi untuk dirasakan, diamati, dan dipahami seiring waktu.\nIni juga memperkenalkan secara lembut konsep bertahan hidup di musim dingin — bagaimana hewan tetap hangat, menemukan perlindungan, dan bergerak dalam dingin secara alami.",
        p7: "❄️ Temukan dunia hewan North Dakota\n\nJelajahi lagu dan cerita di mana hewan musim dingin menjadi hidup — perlahan, lembut, dan dengan cara yang benar-benar dapat dirasakan oleh anak-anak.",
