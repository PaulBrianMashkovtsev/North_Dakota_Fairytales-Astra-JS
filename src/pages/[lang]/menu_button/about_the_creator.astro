const lang = Astro.params.lang;


const text = {
    en: {
        subtitle: "", // Здесь нужна запятая
        p1: `About the Creator`, // Нужна запятая

        p2: `North Dakota Fairytales is an original winter-themed children’s storytelling brand created by Paul Brian Mashkovtsev.`, // Нужна запятая

        p3: `The project features original characters, songs, and stories inspired by the winter landscapes and atmosphere 
        of North Dakota. It focuses on calm, cozy, and safe storytelling for children and does not retell Native American 
        legends or historical folklore.`, // Нужна запятая

        p4: `North Dakota Fairytales was created by an independent author and storyteller with a deep interest in cultural 
        heritage, childhood imagination, and thoughtful storytelling.`,

        p5: `The creator works across writing, music, and visual concepts, focusing on calm, winter-themed stories 
        designed to support children’s emotional well-being. Each project element — stories, songs, and illustrations — 
        is developed with careful attention to atmosphere, language, and emotional tone.`,

        p6: `North Dakota Fairytales is a long-term creative project guided by a consistent artistic vision and a belief 
        in gentle storytelling as an important part of childhood.`
    }, // Запятая перед следующим языком (если он есть ниже)



    es: {
        subtitle: "", // Здесь нужна запятая
        p1: `Sobre el Creador`, // Нужна запятая

        p2: `North Dakota Fairytales es una marca original de narración infantil con temática invernal, creada por Paul 
        Brian Mashkovtsev.`, // Нужна запятая

        p3: `El proyecto presenta personajes, canciones e historias originales inspiradas en los paisajes invernales y 
        la atmósfera de Dakota del Norte. Se centra en una narración tranquila, acogedora y segura para niños, y no
         reinterpreta leyendas nativas americanas ni folclore histórico.`, // Нужна запятая

        p4: `North Dakota Fairytales fue creado por un autor y narrador independiente con un profundo interés en el 
        patrimonio cultural, la imaginación infantil y la narración reflexiva.`,

        p5: `El creador trabaja en escritura, música y conceptos visuales, centrándose en historias invernales calmadas 
        diseñadas para apoyar el bienestar emocional de los niños. Cada elemento del proyecto — historias, canciones e 
        ilustraciones — se desarrolla con especial atención a la atmósfera, el lenguaje y el tono emocional.`,

        p6: `North Dakota Fairytales es un proyecto creativo a largo plazo, guiado por una visión artística coherente y 
        por la convicción de que la narración suave es una parte esencial de la infancia.`
    }, // Запятая перед следующим языком (если он есть ниже)


    fr: {
        subtitle: "", // Здесь нужна запятая
        p1: `À propos du Créateur`, // Нужна запятая

        p2: `North Dakota Fairytales est une marque originale de récits pour enfants sur le thème de l’hiver, créée par 
        Paul Brian Mashkovtsev.`, // Нужна запятая

        p3: `Le projet propose des personnages, des chansons et des histoires originales inspirés des paysages hivernaux
         et de l’atmosphère du Dakota du Nord. Il met l’accent sur une narration calme, chaleureuse et sûre pour les 
         enfants, et ne reprend pas les légendes amérindiennes ni le folklore historique.`, // Нужна запятая

        p4: `North Dakota Fairytales a été créé par un auteur et conteur indépendant, animé par un intérêt profond pour 
        le patrimoine culturel, l’imaginaire de l’enfance et la narration réfléchie.`,

        p5: `Le créateur travaille à travers l’écriture, la musique et les concepts visuels, en se concentrant sur des 
        histoires hivernales calmes conçues pour soutenir le bien-être émotionnel des enfants. Chaque élément du projet — 
        histoires, chansons et illustrations — est développé avec une attention particulière portée à l’atmosphère, au 
        langage et à la tonalité émotionnelle.`,

        p6: `North Dakota Fairytales est un projet créatif à long terme, guidé par une vision artistique cohérente et 
        par la conviction que la narration douce est une composante essentielle de l’enfance.`
    }, // Запятая перед следующим языком (если он есть ниже)

    ar: {
        subtitle: "", // Здесь нужна запятая
        p1: `عن المُنشئ`,
        p2: `نورث داكوتا فيري تايلز 
        (North Dakota Fairytales) هي علامة أصلية لسرد قصص الأطفال ذات الطابع الشتوي، أنشأها بول براين ماشكوفتسيف.`,
        p3: `يضم المشروع شخصيات وأغاني وقصصًا أصلية مستوحاة من المناظر الطبيعية الشتوية وأجواء ولاية نورث داكوتا. 
        ويركّز على سرد هادئ ودافئ وآمن للأطفال، ولا يعيد رواية أساطير السكان الأصليين أو الحكايات التاريخية الشعبية.`,
        p4: `تم إنشاء North Dakota Fairytales على يد مؤلف وراوٍ مستقل يهتم بالتراث الثقافي، وخيال الطفولة، والسرد القصصي المتوازن.`,
        p5: `يعمل المُنشئ في مجالات
         الكتابة والموسيقى والتصميم البصري، مع التركيز على قصص شتوية هادئة تهدف إلى دعم السلامة العاطفية للأطفال. يتم
         تطوير كل عنصر من عناصر المشروع — القصص والأغاني والرسومات — بعناية خاصة للأجواء واللغة والنبرة العاطفية.`,
        p6: `يُعد North Dakota Fairytales
         مشروعًا إبداعيًا طويل المدى، يستند إلى رؤية فنية متسقة وإيمان بأهمية السرد الهادئ كجزء أساسي من تجربة الطفولة.`
    }, // Запятая перед следующим языком (если он есть ниже)

    ru: {
        subtitle: "",
        p1: `Об авторе`,
        p2: `North Dakota Fairytales — это авторский мир зимних историй для детей, созданный писателем и рассказчиком 
        Полом Брайаном Машковцевым.`,
    p3: `В этом мире живут добрые персонажи, звучат тихие зимние песни и рождаются новые сказки, вдохновлённые 
    заснеженными пейзажами Северной Дакоты. Проект создаёт спокойные, уютные и безопасные истории для детей и не 
    пересказывает легенды коренных народов Америки или исторический фольклор.`,
    p4: `Проект был создан независимым автором и рассказчиком, который глубоко интересуется культурным наследием,
     детским воображением и искусством вдумчивого повествования.`,
    p5: `Создатель работает на пересечении литературы, музыки и визуальных идей, создавая спокойные зимние истории, 
    направленные на поддержку эмоционального благополучия детей. Каждая история, песня и иллюстрация создаётся с 
    вниманием к атмосфере, языку и мягкому эмоциональному тону.`,
    p6: `North Dakota Fairytales — это долгосрочный творческий проект, основанный на едином художественном 
    видении и вере в то, что доброе и спокойное повествование является важной частью детства.`
},

    ur: {
        subtitle: "",
        p1: `مصنف کے بارے میں`,

        p2: `North Dakota Fairytales بچوں کے لیے سردیوں کی کہانیوں کی ایک تخلیقی
         دنیا ہے، جسے مصنف اور کہانی سنانے والے پال برائن مشکوفٹسف نے تخلیق کیا ہے۔`,

p3: `اس دنیا میں مہربان کردار بستے ہیں، نرم اور پرسکون سردیوں کے گیت سنائی دیتے ہیں، اور نئی کہانیاں جنم لیتی ہیں جو
 نارتھ ڈکوٹا کے برفیلے مناظر سے متاثر ہیں۔ یہ منصوبہ بچوں کے لیے پُرسکون، محفوظ اور دل کو سکون دینے والی کہانیاں
 تخلیق کرتا ہے اور مقامی امریکی اقوام کی روایتی داستانوں یا تاریخی لوک کہانیوں کو دوبارہ بیان نہیں کرتا۔`,

p4: `یہ منصوبہ ایک آزاد مصنف اور
 کہانی سنانے والے نے تخلیق کیا، جسے ثقافتی ورثے، بچوں کے تخیل اور بامعنی کہانی سنانے کے فن میں گہری دلچسپی ہے۔`,

p5: `تخلیق کار تحریر، موسیقی اور بصری تصورات کے سنگم
 پر کام کرتا ہے اور ایسی پُرسکون سردیوں کی کہانیاں تخلیق کرتا ہے جو بچوں کی جذباتی بھلائی کی حمایت کریں۔ منصوبے
 کا ہر حصہ — کہانیاں، گیت اور تصویریں — ماحول، زبان اور نرم جذباتی لہجے پر خاص توجہ کے ساتھ تیار کیا جاتا ہے۔`,

p6: `North Dakota Fairytales ایک طویل مدتی تخلیقی منصوبہ ہے جو ایک واضح فنکارانہ وژن اور
 اس یقین سے رہنمائی لیتا ہے کہ نرم اور مہربان کہانیاں بچپن کا ایک اہم حصہ ہوتی ہیں۔`
},

    hi: {
        subtitle: "",
        p1: `लेखक के बारे में`,

        p2: `North Dakota Fairytales बच्चों के लिए सर्दियों की कहानियों की एक रचनात्मक दुनिया है, जिसे लेखक और कथाकार पॉल ब्रायन माश्कोवत्सेव ने बनाया है।`,

p3: `इस दुनिया में दयालु पात्र रहते हैं, शांत सर्दियों के गीत सुनाई देते हैं, और नई कहानियाँ जन्म लेती हैं जो नॉर्थ डकोटा के बर्फ़ से ढके दृश्यों से प्रेरित हैं। यह 
परियोजना बच्चों के लिए शांत, सुरक्षित और सुकून देने वाली कहानियाँ बनाती है और मूल अमेरिकी समुदायों की पारंपरिक कथाओं या ऐतिहासिक लोककथाओं को दोहराती नहीं है।`,

p4: `इस परियोजना को एक स्वतंत्र लेखक और कथाकार ने बनाया है, जिसे सांस्कृतिक विरासत, बच्चों की कल्पना और विचारपूर्ण कहानी कहने की कला में गहरी रुचि है।`,

p5: `रचनाकार लेखन, संगीत और दृश्य कल्पनाओं के संगम पर काम करते हैं और ऐसी शांत सर्दियों की कहानियाँ बनाते हैं जो बच्चों के भावनात्मक संतुलन और भलाई 
का समर्थन करती हैं। परियोजना का हर तत्व — कहानियाँ, गीत और चित्र — वातावरण, भाषा और कोमल भावनात्मक स्वर पर विशेष ध्यान के साथ बनाया जाता है।`,

p6: `North Dakota Fairytales एक दीर्घकालिक रचनात्मक परियोजना है, जिसे एक स्पष्ट कलात्मक दृष्टि और इस विश्वास द्वारा मार्गदर्शन मिलता है कि कोमल और 
दयालु कहानियाँ बचपन का एक महत्वपूर्ण हिस्सा होती हैं।`
},

    bn: {
        subtitle: "",
        p1: `স্রষ্টা সম্পর্কে`,

        p2: `North Dakota Fairytales শিশুদের জন্য শীতের গল্পের এক সৃজনশীল জগৎ, যা লেখক ও গল্পকার পল ব্রায়ান মাশকভৎসেভ তৈরি করেছেন।`,

p3: `এই জগতে বাস করে দয়ালু চরিত্ররা, শোনা যায় নরম শীতের গান, আর জন্ম নেয় নতুন গল্প—যেগুলো অনুপ্রাণিত হয়েছে নর্থ ডাকোটার তুষারে ঢাকা
 প্রাকৃতিক দৃশ্য থেকে। এই প্রকল্পটি শিশুদের জন্য শান্ত, নিরাপদ এবং হৃদয়কে প্রশান্ত করে এমন গল্প তৈরি করে এবং এটি আমেরিকার আদিবাসী জনগোষ্ঠীর
  কিংবদন্তি বা ঐতিহাসিক লোককথা পুনরায় বর্ণনা করে না।`,

p4: `এই প্রকল্পটি একজন স্বাধীন লেখক ও গল্পকারের সৃষ্টি, যিনি সাংস্কৃতিক ঐতিহ্য, শিশুদের কল্পনা এবং চিন্তাশীল গল্প বলার শিল্পের প্রতি গভীর আগ্রহ রাখেন।`,

p5: `স্রষ্টা লেখা, সঙ্গীত এবং দৃশ্যকল্পের সংযোগস্থলে কাজ করেন, এমন শান্ত শীতের গল্প তৈরি করেন যা শিশুদের মানসিক সুস্থতা ও আবেগগত ভারসাম্যকে 
সমর্থন করে। প্রকল্পের প্রতিটি উপাদান — গল্প, গান এবং চিত্র — পরিবেশ, ভাষা এবং কোমল আবেগঘন সুরের প্রতি যত্ন নিয়ে তৈরি করা হয়।`,

p6: `North Dakota Fairytales একটি দীর্ঘমেয়াদি সৃজনশীল প্রকল্প, যা একটি সুস্পষ্ট শিল্পীসুলভ দৃষ্টিভঙ্গি এবং এই বিশ্বাস দ্বারা পরিচালিত যে কোমল ও 
দয়ালু গল্প বলা শিশুকালের একটি গুরুত্বপূর্ণ অংশ।`
},

    fa: {
        subtitle: "",
        p1: `درباره خالق`,

        p2: `North Dakota Fairytales دنیایی خلاقانه از داستان‌های زمستانی
         برای کودکان است که توسط نویسنده و داستان‌پرداز پل برایان ماشکوف‌تسف ساخته شده است.`,

        p3: `در این دنیا شخصیت‌های مهربان زندگی می‌کنند، ترانه‌های آرام زمستانی شنیده
         می‌شود و داستان‌های تازه‌ای متولد می‌شوند که از مناظر برفی ایالت داکوتای شمالی الهام گرفته‌اند. این پروژه داستان‌هایی
         آرام، امن و دلنشین برای کودکان خلق می‌کند و افسانه‌های بومیان آمریکا یا فولکلور تاریخی را بازگو نمی‌کند.`,

    p4: `این پروژه توسط یک
     نویسنده و داستان‌گوی مستقل ایجاد شده است که علاقه‌ای عمیق به میراث فرهنگی، تخیل کودکان و هنر روایت اندیشمندانه دارد.`,

    p5: `خالق این پروژه در نقطه تلاقی نوشتن، موسیقی و
     ایده‌های بصری فعالیت می‌کند و داستان‌های آرام زمستانی می‌آفریند که به آرامش و سلامت عاطفی کودکان کمک می‌کنند. هر بخش
     از این پروژه — داستان‌ها، ترانه‌ها و تصویرگری‌ها — با توجهی ویژه به فضا، زبان و لحن احساسی ملایم ساخته می‌شود.`,

    p6: `North Dakota Fairytales یک پروژه خلاقانه بلندمدت است که با یک دیدگاه هنری روشن هدایت
     می‌شود و بر این باور استوار است که داستان‌گویی آرام و مهربان بخش مهمی از دوران کودکی است.`
},

    pt: {
        subtitle: "",
        p1: `Sobre o Criador`,

        p2: `North Dakota Fairytales é um mundo criativo de histórias de inverno para crianças, criado pelo escritor e 
        contador de histórias Paul Brian Mashkovtsev.`,

        p3: `Neste mundo vivem personagens gentis, ouvem-se canções suaves de inverno e nascem novas histórias 
        inspiradas pelas paisagens cobertas de neve de North Dakota. O projeto cria histórias calmas, acolhedoras e 
        seguras para crianças e não reconta lendas dos povos nativos da América nem folclore histórico.`,

        p4: `O projeto foi criado por um autor e contador de histórias independente, com profundo interesse pelo 
        patrimônio cultural, pela imaginação infantil e pela arte da narrativa cuidadosa.`,

        p5: `O criador trabalha na interseção entre escrita, música e conceitos visuais, desenvolvendo histórias 
        tranquilas de inverno pensadas para apoiar o bem-estar emocional das crianças. Cada elemento do projeto — 
        histórias, canções e ilustrações — é desenvolvido com atenção especial à atmosfera, à linguagem e ao tom emocional suave.`,

    p6: `North Dakota Fairytales é um projeto criativo de longo prazo guiado por uma visão artística consistente e pela 
    crença de que histórias gentis e tranquilas são uma parte importante da infância.`
},

    ms: {
        subtitle: "",
        p1: `Tentang Pencipta`,

        p2: `North Dakota Fairytales ialah sebuah dunia kreatif cerita musim sejuk untuk kanak-kanak yang dicipta oleh 
        penulis dan pencerita Paul Brian Mashkovtsev.`,

        p3: `Dalam dunia ini tinggal watak-watak yang baik hati, kedengaran lagu musim sejuk yang lembut, dan lahir 
        cerita-cerita baharu yang diinspirasikan oleh pemandangan bersalji di North Dakota. Projek ini mencipta cerita 
        yang tenang, selesa dan selamat untuk kanak-kanak, dan tidak menceritakan semula legenda masyarakat pribumi 
        Amerika atau cerita rakyat sejarah.`,

        p4: `Projek ini dicipta oleh seorang penulis dan pencerita bebas yang mempunyai minat mendalam terhadap 
        warisan budaya, imaginasi kanak-kanak dan seni penceritaan yang penuh perhatian.`,

        p5: `Pencipta projek ini bekerja di persimpangan penulisan, muzik dan konsep visual, menghasilkan cerita 
