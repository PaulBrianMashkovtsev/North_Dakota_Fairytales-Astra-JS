const lang = Astro.params.lang;


const text = {
    en: {
        subtitle: "", // Здесь нужна запятая
        p1: `Project Vision`,

        p2: `The long-term vision of North Dakota Fairytales is to build a calm and culturally meaningful storytelling 
        universe for children and families across languages and generations.`,

        p3: `The project seeks to preserve the emotional depth of traditional storytelling while presenting it in a 
        modern, gentle format suited to today’s children. Through winter-themed stories, music, illustrations, and 
        interactive experiences, North Dakota Fairytales aims to offer a space where imagination can grow without 
        noise, pressure, or overstimulation.`,

        p4: `Over time, the project envisions expanding its library of stories, songs, books, and digital experiences 
        while remaining faithful to its core principles: calm storytelling, emotional safety, cultural respect, and
         creative consistency.`,

        p5: `North Dakota Fairytales aspires to become a trusted creative reference for families seeking thoughtful 
        and peaceful content that values imagination, warmth, and timeless human values.`
