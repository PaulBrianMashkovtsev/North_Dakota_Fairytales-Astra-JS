import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
    return [
        { params: { lang: "en" } },
        { params: { lang: "es" } },
        { params: { lang: "fr" } },
        { params: { lang: "ar" } },
        { params: { lang: "ru" } },
        { params: { lang: "ur" } },
        { params: { lang: "hi" } },
        { params: { lang: "bn" } },
        { params: { lang: "fa" } },
        { params: { lang: "pt" } },
        { params: { lang: "ms" } },
        { params: { lang: "id" } },
        { params: { lang: "de" } },
        { params: { lang: "ca" } },
        { params: { lang: "az" } },
        { params: { lang: "hy" } },
        { params: { lang: "haw" } },
        { params: { lang: "tt" } }
        // Добавьте сюда другие языки, которые у вас есть
    ];
}

const lang = Astro.params.lang;


const text = {
    en: {
        subtitle: "", // Здесь нужна запятая
        p1: `Our Mission`,

        p2: `The mission of North Dakota Fairytales is to create calm, meaningful winter stories and music that nurture 
        a child’s imagination and emotional well-being.`,

        p3: `Through gentle storytelling, soft music, and carefully illustrated scenes, the brand offers children 
        a peaceful alternative to fast and overstimulating media. Each story is created to be safe, thoughtful, 
        and rooted in timeless human values such as kindness, empathy, courage, and respect.`,

        p4: `North Dakota Fairytales is dedicated exclusively to winter-themed storytelling, preserving the quiet 
        beauty of snowy landscapes and long northern evenings as a space for reflection, warmth, and imagination.`
    }, // Запятая перед следующим языком (если он есть ниже)



    es: {
        subtitle: "", // Здесь нужна запятая
        p1: `Nuestra Misión`,

        p2: `La misión de North Dakota Fairytales es crear historias y música invernales tranquilas y significativas que
         nutran la imaginación y el bienestar emocional de los niños.`,

        p3: `A través de una narración suave, música delicada e ilustraciones cuidadosamente creadas, la marca ofrece a 
        los niños una alternativa pacífica a los medios rápidos y sobreestimulantes. Cada historia se desarrolla de 
        manera segura y reflexiva, transmitiendo valores humanos atemporales como la bondad, la empatía, el valor y el 
        respeto.`,

        p4: `North Dakota Fairytales está dedicada exclusivamente a la narración con temática invernal, preservando 
        la belleza silenciosa de los paisajes nevados y las largas noches del norte como un espacio de calma, calidez 
        e imaginación.`
    }, // Запятая перед следующим языком (если он есть ниже)


    fr: {
        subtitle: "", // Здесь нужна запятая
        p1: `Notre Mission`,

        p2: `La mission de North Dakota Fairytales est de créer des histoires et des musiques hivernales calmes et 
        porteuses de sens, favorisant l’imagination et le bien-être émotionnel des enfants.`,

        p3: `Grâce à une narration douce, une musique apaisante et des illustrations soigneusement réalisées, la 
        marque propose une alternative paisible aux médias rapides et surstimulants. Chaque histoire est conçue 
        pour être sûre, réfléchie et ancrée dans des valeurs humaines intemporelles telles que la bienveillance, 
        l’empathie, le courage et le respect.`,

        p4: `North Dakota Fairytales se consacre exclusivement à la narration à thème hivernal, mettant en valeur la 
