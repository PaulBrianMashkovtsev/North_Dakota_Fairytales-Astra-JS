---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { translations } from "../../../lib/i18n";
import {
    songs,
    ALL_CATEGORIES,
    SUPPORTED_LANGS,
    categoryTranslations,
    songIsPublishedInLang,
    extractYouTubeId,
} from "../../../data/songs";
import { oldSnowSongHref } from "../../../lib/songPaths";

export async function getStaticPaths() {
    return SUPPORTED_LANGS.flatMap((lang) =>
        ALL_CATEGORIES.map((category) => ({
            params: { lang, category },
        })),
    );
}

const { lang, category } = Astro.params;
const currentLang = SUPPORTED_LANGS.includes(lang ?? "") ? (lang as "en" | "es" | "fr" | "ar") : "en";
const currentCategory = category ?? "";
const isRTL = currentLang === "ar";

const t = (translations[currentLang] || translations.en) as any;
const localizedCategoryMap = categoryTranslations[currentLang] as Record<string, string>;
const localizedCategoryName =
    localizedCategoryMap[currentCategory] ||
    currentCategory.replaceAll("_", " ");

const pageH1 = `${localizedCategoryName} - ${t.category_winter_songs_suffix}`;
const pageH2 = t.category_h2_discover_magical;

const categorySongs = songs
    .filter((song) => Array.isArray(song.categories) && song.categories.includes(currentCategory))
    .filter((song) => songIsPublishedInLang(song, currentLang))
    .map((song) => {
        const localized = song.translations[currentLang] || song.translations.en;
        const youtubeUrl =
            song.youtubeByLang?.[currentLang] || song.youtubeByLang?.en || "";
        const youtubeId = extractYouTubeId(youtubeUrl);
        return {
            slug: song.slug,
            title: localized.title,
            description: localized.description,
            href: oldSnowSongHref(currentLang, song.slug),
            thumbUrl: youtubeId
                ? `https://i.ytimg.com/vi/${youtubeId}/mqdefault.jpg`
                : null,
        };
    });
---

<BaseLayout lang={currentLang} title={pageH1} description={pageH2} isAuthorPage={true}>
    <section dir={isRTL ? "rtl" : "ltr"} class="category-page">
        <div class="category-page__intro">
            <h1 class="category-page__h1">{pageH1}</h1>
            <h2 class="category-page__h2">{pageH2}</h2>
        </div>

        {categorySongs.length === 0 ? (
            <p class="category-page__empty">{t.category_empty_state}</p>
        ) : (
            <div class="category-song-grid">
                {categorySongs.map((song) => (
                    <a href={song.href} class="category-song-card">
                        {song.thumbUrl ? (
                            <div class="category-song-thumb">
                                <img
                                    src={song.thumbUrl}
                                    alt=""
                                    width="320"
                                    height="180"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        ) : (
                            <div class="category-song-thumb category-song-thumb--empty" aria-hidden="true">
                                —
                            </div>
                        )}
                        <div class="category-song-body">
                            <h3 class="category-song-title">{song.title}</h3>
                            {song.description?.trim() ? (
                                <p class="category-song-desc">{song.description}</p>
                            ) : null}
                            <span class="category-song-hint">
                                {t.category_song_open_full ?? "Open full page"}
                            </span>
                        </div>
                    </a>
                ))}
            </div>
        )}
    </section>
</BaseLayout>

<style>
    .category-page {
        box-sizing: border-box;
        max-width: 64rem;
        margin: 0 auto;
        width: 100%;
        padding: 2.5rem 1rem 2rem;
    }
    .category-page__intro {
        text-align: center;
        margin-bottom: 2rem;
    }
    .category-page__h1 {
        margin: 0;
        font-size: clamp(1.35rem, 4vw, 1.85rem);
        font-weight: 800;
        color: #fff;
        line-height: 1.2;
    }
    .category-page__h2 {
        margin: 0.5rem 0 0;
        font-size: clamp(0.95rem, 2.5vw, 1.1rem);
        font-weight: 400;
        color: #e2e8f0;
    }
    .category-page__empty {
        text-align: center;
        color: #e2e8f0;
    }
    .category-song-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @media (min-width: 640px) {
        .category-song-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .category-song-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
    .category-song-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-radius: 1rem;
        border: 1px solid rgba(203, 213, 225, 0.35);
        background: rgba(30, 41, 59, 0.45);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        text-decoration: none;
        color: inherit;
        transition:
            border-color 0.2s ease,
            background 0.2s ease,
            transform 0.15s ease;
    }
    .category-song-card:hover {
        border-color: rgba(226, 232, 240, 0.45);
        background: rgba(51, 65, 85, 0.4);
        transform: translateY(-2px);
    }
    .category-song-card:focus-visible {
        outline: 2px solid #7dd3fc;
        outline-offset: 2px;
    }
    .category-song-thumb {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        background: #0f172a;
        overflow: hidden;
    }
    .category-song-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .category-song-thumb--empty {
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 1.25rem;
    }
    .category-song-body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1rem 1.1rem 1.15rem;
        text-align: start;
    }
    .category-song-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.3;
    }
    .category-song-desc {
        margin: 0.35rem 0 0;
        font-size: 0.875rem;
        line-height: 1.45;
        color: #e2e8f0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .category-song-hint {
        margin-top: 0.75rem;
        display: inline-block;
        width: fit-content;
        font-size: 0.875rem;
        font-weight: 600;
        color: #bae6fd;
        text-decoration: underline;
        text-underline-offset: 3px;
    }
    .category-song-card:hover .category-song-hint {
        color: #fff;
    }
</style>
