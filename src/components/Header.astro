const t = translations[currentLang as keyof typeof translations] || translations.en;
const brand =
    brandNames[currentLang as keyof typeof brandNames] ?? brandNames.en;

/** Ссылка «Winter Music» в выпадающем меню Winter Magic — только эти языки. */
const winterMusicHubLangs = new Set(["en", "es", "fr", "ar"]);
const showWinterMusicHubLink = winterMusicHubLangs.has(currentLang);

const winterMusicHubLabels: Record<string, string> = {
    en: "Winter Music",
    es: "Música de Invierno",
    fr: "Musique d\u2019hiver",
    ar: "موسيقى الشتاء"
};
const winterMusicHubLabel = winterMusicHubLabels[currentLang] ?? "";
---

<header class="ndf-header">
    <div class="absolute inset-0 pointer-events-none snow-gradient"></div>

    <div class="ndf-header-container">
        <div class="ndf-spacer"></div>

        <div class="ndf-brand-box text-white">
            <h1 class="brand-title">
                {brand.display}
                <span class="sr-only"> - {brand.search}</span>
            </h1>
            <p class="subtitle">{t.subtitle}</p>
        </div>

        <div class="ndf-menu-wrapper">
            <div class="ndf-menu-cluster">
                <div class="ndf-menu-dropdown-host">
                    <button
                        type="button"
                        id="ndfWinterMagicBtn"
                        class="ndf-menu-btn ndf-winter-magic-btn"
                        aria-expanded="false"
                        aria-controls="ndfWinterMagicDD"
                    >
                        <span class="ndf-magic-icon-wrap" aria-hidden="true">
                            <span class="globe-icon">🔮</span>
                        </span>
                        <div class="snow-container" aria-hidden="true"></div>
                        <span class="ndf-menu-label">{t.winterMagic}</span>
                    </button>
                    <nav id="ndfWinterMagicDD" class="ndf-menu-dd" aria-hidden="true">
                        {showWinterMusicHubLink && (
                            <a href={`/${currentLang}/old-snow-music/`}>
                                {winterMusicHubLabel}
                            </a>
                        )}
                    </nav>
                </div>
                <div class="ndf-menu-dropdown-host">
                    <button type="button" id="ndfMenuBtn" class="ndf-menu-btn" aria-label={t.ariaLabel} aria-expanded="false" aria-controls="ndfMenuDD">
                        <span class="ndf-snowflake">❄️</span>
                        <span class="ndf-menu-label">{t.menuBtn}</span>
                    </button>

                    <nav id="ndfMenuDD" class="ndf-menu-dd" aria-hidden="true">
                        <a href={`/${currentLang}/menu_button/about/`}>{t.about}</a>
                        <a href={`/${currentLang}/menu_button/about_the_creator/`}>{t.creator}</a>
                        <a href={`/${currentLang}/menu_button/faq/`}>{t.faq}</a>
                        <a href={`/${currentLang}/menu_button/mission/`}>{t.mission}</a>
                        <a href={`/${currentLang}/menu_button/manifesto/`}>{t.manifesto}</a>
                        <div class="ndf-sep"></div>
                        <a href="mailto:contact@northdakotafairytales.org">
                            {t.contact}
                        </a>
                        <div class="ndf-sep"></div>
                        <a href={`/${currentLang}/menu_button/privacy/`}>{t.privacy}</a>
                        <a href={`/${currentLang}/menu_button/project_vision/`}>{t.vision}</a>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</header>

<style>
    .ndf-header {
        position: relative;
        padding: 20px 0;
        overflow: visible;
        z-index: 50;
    }

    .ndf-header-container {
        display: flex;
        align-items: center; /* Центрируем по вертикали */
        justify-content: flex-end; /* Прижимаем всё содержимое (кнопку) к правому краю */
        position: relative; /* Важно для привязки заголовка */
        min-height: 80px; /* Укажите примерную высоту вашего хедера */
        padding: 0 24px;
    }

    .ndf-spacer {
        width: 130px;
        display: none;
    }
    @media (min-width: 768px) { .ndf-spacer { display: block; } }

    .ndf-brand-box {
        text-align: center;
        flex: 1;
    }

    .brand-title {
        font-size: clamp(60px, 7vw, 120px); /* Адаптивный размер вместо фиксированного 80px */
        font-weight: 900;
        color: royalblue;
        text-shadow: 0 0 20px rgba(65, 105, 225, 0.5);
        margin: 0;
        line-height: 1.1;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .subtitle {
        font-size: clamp(2rem, 2vw, 2rem);
        color: lightblue;
        margin-top: 10px;
    }

    .ndf-menu-wrapper {
        position: absolute;
        top: 20px;     /* отступ сверху */
        /* right: 20px; отступ справа */
        width: auto;   /* убираем жесткую ширину 130px, если она мешает */
        z-index: 100;  /* чтобы кнопка была поверх других элементов */
    }

    .ndf-menu-cluster {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
        margin-inline-start: auto;
        margin-top: 70px;
    }

    .ndf-menu-dropdown-host {
        position: relative;
    }

    .ndf-menu-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(25, 45, 70, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 10px 22px;
        border-radius: 99px;
        color: white;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .ndf-menu-label {
        font-size: 25px;
        position: relative;
        z-index: 1;
        unicode-bidi: isolate;
    }

    .ndf-winter-magic-btn {
        position: relative;
        overflow: hidden;
        user-select: none;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), background 0.3s ease, box-shadow 0.3s ease;
    }

    .ndf-winter-magic-btn .snow-container {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .ndf-magic-icon-wrap {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ndf-winter-magic-btn .globe-icon {
        font-size: 35px;
        line-height: 1;
    }

    :global(.snowflake-mini) {
        position: absolute;
        color: white;
        font-size: 10px;
        top: -10px;
        animation: ndf-fall 1.2s linear forwards;
    }

    @keyframes ndf-fall {
        0% { transform: translateY(0) rotate(0deg); opacity: 1; }
        100% { transform: translateY(52px) rotate(360deg); opacity: 0; }
    }

    .ndf-winter-magic-btn:hover {
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.5);
    }

    /* ❄️ Snowflake Animation */
    .ndf-snowflake {
        font-size: 35px;
        animation: sparkle 3s ease-in-out infinite;
    }

    @keyframes sparkle {
        0%, 100% {
            opacity: 0.9;
            transform: rotate(0deg) scale(1);
            color: #ffffff;
            text-shadow: 0 0 6px #dbeafe;
        }
        50% {
            opacity: 1;
            transform: rotate(18deg) scale(1.25);
            color: #b3e5fc;
            text-shadow: 0 0 14px #b3e5fc;
        }
    }

    .ndf-menu-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.05);
    }

    .ndf-menu-dd {
        display: none;
        position: absolute;
        top: calc(100% + 10px); /* Смещение ровно под кнопку */
        right: 0;
        z-index: 1000;
        width: 240px;
        background: rgba(15, 25, 45, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 16px;
        padding: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        flex-direction: column;
    }

    .ndf-menu-dd.open {
        display: flex;
    }

    .ndf-menu-dd a {
        color: white;
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        transition: background 0.2s;
        text-align: start;
    }

    .ndf-menu-dd a:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #818cf8;
    }

    .ndf-sep {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin: 8px 0;
    }

    .snow-gradient {
        background: radial-gradient(circle at 50% -20%, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    }

    /* Поддержка RTL */
    :global(html[dir="rtl"]) .ndf-menu-dd {
        right: auto;
        left: 0;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 34px;
            line-height: 1.15;
            word-break: break-word;
        }
    }

</style>

<script is:inline>
    (function() {
        const menuBtn = document.getElementById("ndfMenuBtn");
        const menu = document.getElementById("ndfMenuDD");
        const winterBtn = document.getElementById("ndfWinterMagicBtn");
        const winterMenu = document.getElementById("ndfWinterMagicDD");

        function closeMainMenu() {
            if (menu && menuBtn) {
                menu.classList.remove("open");
                menuBtn.setAttribute("aria-expanded", "false");
            }
        }

        function closeWinterMenu() {
            if (winterMenu && winterBtn) {
                winterMenu.classList.remove("open");
                winterBtn.setAttribute("aria-expanded", "false");
            }
        }

        function playWinterSnowFx() {
            if (!winterBtn) return;
            winterBtn.style.transform = "scale(1.05) rotate(15deg)";
            setTimeout(function() { winterBtn.style.transform = "rotate(-15deg) scale(1.05)"; }, 100);
            setTimeout(function() { winterBtn.style.transform = ""; }, 200);
            var container = winterBtn.querySelector(".snow-container");
            for (var i = 0; i < 8; i++) {
                var snow = document.createElement("span");
                snow.className = "snowflake-mini";
                snow.textContent = "\u2744";
                snow.style.left = Math.random() * 100 + "%";
                snow.style.animationDelay = Math.random() * 0.2 + "s";
                if (container) container.appendChild(snow);
                setTimeout(function(s) { return function() { s.remove(); }; }(snow), 1200);
            }
        }

        if (menuBtn && menu) {
            menuBtn.addEventListener("click", function(e) {
                e.stopPropagation();
                closeWinterMenu();
                var isOpen = menu.classList.toggle("open");
                menuBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
            });
        }

        if (winterBtn && winterMenu) {
            winterBtn.addEventListener("click", function(e) {
                e.stopPropagation();
                closeMainMenu();
                var isOpen = winterMenu.classList.toggle("open");
                winterBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
                if (isOpen) {
                    playWinterSnowFx();
                }
            });
        }

        document.addEventListener("click", function(e) {
            var t = e.target;
            var inMain = menu && (menu.contains(t) || t === menuBtn);
            var inWinter = winterMenu && (winterMenu.contains(t) || t === winterBtn || (winterBtn && winterBtn.contains(t)));
            if (!inMain) closeMainMenu();
            if (!inWinter) closeWinterMenu();
        });
    })();
</script>
