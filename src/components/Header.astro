---

<header class="ndf-header">
    <div class="absolute inset-0 pointer-events-none snow-gradient"></div>

    <div class="ndf-header-container">
        <div class="ndf-spacer"></div>

        <div class="ndf-brand-box text-white">
            <h1 class="brand-title">{brand}</h1>
            <p class="subtitle">{t.subtitle}</p>
        </div>

        <div class="ndf-menu-wrapper">
            <button id="ndfMenuBtn" class="ndf-menu-btn" aria-label={t.ariaLabel} aria-expanded="false">
                <span class="ndf-snowflake">❄️</span>
                <span class="ndf-menu-label">{t.menuBtn}</span>
            </button>

            <nav id="ndfMenuDD" class="ndf-menu-dd" aria-hidden="true">
                <a href={`/${currentLang}/about`}>{t.about}</a>
                <a href={`/${currentLang}/about_the_creator`}>{t.creator}</a>
                <a href={`/${currentLang}/faq`}>{t.faq}</a>
                <a href={`/${currentLang}/mission`}>{t.mission}</a>
                <a href={`/${currentLang}/manifesto`}>{t.manifesto}</a>
                <div class="ndf-sep"></div>
                <a href="mailto:contact@northdakotafairytales.org">
                    {t.contact}
                </a>
                <div class="ndf-sep"></div>
                <a href={`/${currentLang}/privacy`}>{t.privacy}</a>
                <a href={`/${currentLang}/project_vision`}>{t.vision}</a>
            </nav>
        </div>
    </div>
</header>

<style>
    .ndf-header {
        position: relative;
        padding: 20px 0;
        overflow: visible;
        z-index: 50;
    }

    .ndf-header-container {
        display: flex;
        align-items: center; /* Центрируем по вертикали */
        justify-content: flex-end; /* Прижимаем всё содержимое (кнопку) к правому краю */
        position: relative; /* Важно для привязки заголовка */
        min-height: 80px; /* Укажите примерную высоту вашего хедера */
        padding: 0 24px;
    }

    .ndf-spacer {
        width: 130px;
        display: none;
    }
    @media (min-width: 768px) { .ndf-spacer { display: block; } }

    .ndf-brand-box {
        text-align: center;
        flex: 1;
    }

    .brand-title {
        font-size: clamp(60px, 7vw, 120px); /* Адаптивный размер вместо фиксированного 80px */
        font-weight: 900;
        color: royalblue;
        text-shadow: 0 0 20px rgba(65, 105, 225, 0.5);
        margin: 0;
        line-height: 1.1;
    }

    .subtitle {
        font-size: clamp(2rem, 2vw, 2rem);
        color: lightblue;
        margin-top: 10px;
    }

    .ndf-menu-wrapper {
        position: absolute;
        top: 20px;     /* отступ сверху */
        //right: 20px;   /* отступ справа */
        width: auto;   /* убираем жесткую ширину 130px, если она мешает */
        z-index: 100;  /* чтобы кнопка была поверх других элементов */
    }

    /* Если у родителя (html) стоит dir="rtl", флекс-контейнер сам развернет детей */
    :global([dir="rtl"]) .ndf-menu-wrapper {
        flex-direction: row-reverse;
    }

    .ndf-menu-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(25, 45, 70, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 20px 40px;
        border-radius: 99px;
        color: white;
        font-weight: 700;
        font-size: 25px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-inline-start: auto;
    }

    .ndf-menu-label{
        font-size:25px;
    }

    /* ❄️ Snowflake Animation */
    .ndf-snowflake {
        font-size: 35px;
        animation: sparkle 3s ease-in-out infinite;
    }

    @keyframes sparkle {
        0%, 100% {
            opacity: 0.9;
            transform: rotate(0deg) scale(1);
            color: #ffffff;
            text-shadow: 0 0 6px #dbeafe;
        }
        50% {
            opacity: 1;
            transform: rotate(18deg) scale(1.25);
            color: #b3e5fc;
            text-shadow: 0 0 14px #b3e5fc;
        }
    }

    .ndf-menu-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.05);
    }

    .ndf-menu-dd {
        display: none;
        position: absolute;
        top: calc(100% + 10px); /* Смещение ровно под кнопку */
        right: 0;
        z-index: 1000;
        width: 240px;
        background: rgba(15, 25, 45, 0.95);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 16px;
        padding: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        flex-direction: column;
    }

    .ndf-menu-dd.open {
        display: flex;
    }

    .ndf-menu-dd a {
        color: white;
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        transition: background 0.2s;
        text-align: right;
    }

    .ndf-menu-dd a:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #818cf8;
    }

    .ndf-sep {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin: 8px 0;
    }

    .snow-gradient {
        background: radial-gradient(circle at 50% -20%, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    }

    /* Поддержка RTL */
    :global(html[dir="rtl"]) .ndf-menu-dd {
        right: auto;
        left: 0;
    }

</style>

<script is:inline>
    (function() {
        const btn = document.getElementById("ndfMenuBtn");
        const menu = document.getElementById("ndfMenuDD");

        if (btn && menu) {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const isOpen = menu.classList.toggle("open");
                btn.setAttribute("aria-expanded", isOpen);
            });

            document.addEventListener("click", (e) => {
                if (!menu.contains(e.target) && e.target !== btn) {
                    menu.classList.remove("open");
                    btn.setAttribute("aria-expanded", "false");
                }
            });
        }
    })();
</script>