---
// src/components/Schema.astro

interface Props {
    title?: string;
    description?: string;
    lang?: string;
}

const {
    title = "North Dakota Fairytales",
    description,
    lang = "en"
} = Astro.props;

// 🌍 Полный словарь (сохраняем силу проекта)
export const l10n: Record<string, { name: string; desc: string; tags: string[] }> = {
    en: {
        name: "North Dakota Fairytales",
        desc: "Winter children's stories, songs, games, color metaphors and encyclopedia for calm emotional learning.",
        tags: ["songs", "fairytales", "games", "color metaphors", "encyclopedia"]
    },
    es: {
        name: "North Dakota Fairytales",
        desc: "Cuentos, canciones, juegos y metáforas de colores para el aprendizaje emocional.",
        tags: ["canciones", "cuentos", "juegos", "metáforas de colores", "enciclopedia"]
    },
