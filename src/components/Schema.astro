        desc: "کہانیاں، گانے، کھیل اور رنگوں کے استعارے جذباتی سیکھنے کے لیے۔",
        tags: ["گانے", "کہانیاں", "کھیل", "رنگوں کے استعارے", "انسائیکلوپیڈیا"]
    },
    hi: {
        name: "North Dakota Fairytales",
        desc: "कहानियां, गाने, खेल और रंग रूपक भावनात्मक सीखने के लिए।",
        tags: ["गाने", "कहानियां", "खेल", "रंग रूपक", "विश्वकोश"]
    },
    bn: {
        name: "North Dakota Fairytales",
        desc: "গল্প, গান, খেলা এবং রঙের রূপক আবেগীয় শেখার জন্য।",
        tags: ["গান", "গল্প", "খেলা", "রঙের রূপক", "বিশ্বকোষ"]
    },
    fa: {
        name: "North Dakota Fairytales",
        desc: "داستان‌ها، آهنگ‌ها، بازی‌ها و استعاره‌های رنگی برای یادگیری عاطفی.",
        tags: ["آهنگ", "داستان", "بازی", "استعاره‌های رنگی", "دانشنامه"]
    },
    pt: {
        name: "North Dakota Fairytales",
        desc: "Histórias, músicas, jogos e metáforas de cores para aprendizado emocional.",
        tags: ["canções", "histórias", "jogos", "metáforas", "enciclopédia"]
    },
    ms: {
        name: "North Dakota Fairytales",
        desc: "Cerita, lagu, permainan dan metafora warna untuk pembelajaran emosi.",
        tags: ["lagu", "cerita", "permainan", "metafora warna", "ensiklopedia"]
    },
    id: {
        name: "North Dakota Fairytales",
        desc: "Cerita, lagu, permainan dan metafora warna untuk pembelajaran emosional.",
        tags: ["lagu", "cerita", "permainan", "metafora warna", "ensiklopedia"]
    },
    de: {
        name: "North Dakota Fairytales",
        desc: "Geschichten, Lieder, Spiele und Farbmetaphern für emotionales Lernen.",
        tags: ["Lieder", "Geschichten", "Spiele", "Farbenmetaphern", "Enzyklopädie"]
    },
    ca: {
        name: "North Dakota Fairytales",
        desc: "Contes, cançons, jocs i metàfores de colors per a l’aprenentatge emocional.",
        tags: ["cançons", "contes", "jocs", "metàfores", "enciclopèdia"]
    },
    az: {
        name: "North Dakota Fairytales",
        desc: "Nağıllar, mahnılar, oyunlar və rəng metaforaları emosional inkişaf üçün.",
        tags: ["mahnılar", "nağıllar", "oyunlar", "rəng metaforaları", "ensiklopediya"]
    },
    hy: {
        name: "North Dakota Fairytales",
        desc: "Հեքիաթներ, երգեր, խաղեր և գույների փոխաբերություններ հուզական զարգացման համար.",
        tags: ["երգեր", "հեքիաթներ", "խաղեր", "գույներ", "հանրագիտարան"]
    },
    haw: {
        name: "North Dakota Fairytales",
        desc: "Nā moʻolelo, nā mele, nā pāʻani a me nā hoʻohālikelike waihoʻoluʻu no ke aʻo ʻana.",
        tags: ["mele", "moʻolelo", "pāʻani", "hoʻohālikelike", "papa kuhikuhi"]
    },
    tt: {
        name: "North Dakota Fairytales",
        desc: "Әкиятләр, җырлар, уеннар һәм төс метафоралары эмоциональ үсеш өчен.",
        tags: ["җырлар", "әкиятләр", "уеннар", "төс метафоралары", "энциклопедия"]
    }
};

const currentL10n = l10n[lang] || l10n.en;

const siteTitle = title || currentL10n.name;
const siteDesc = description || currentL10n.desc;

const canonicalURL = Astro.url;

// 🔗 ВСЕ платформы (оставляем силу бренда)
const sameAsLinks = [
    "https://www.youtube.com/@NorthDakotaFairytales",
    "https://www.youtube.com/@NorthDakotaFairytalesES",
    "https://www.youtube.com/@NorthDakotaFairytalesFR",
    "https://www.youtube.com/@NorthDakotaFairytalesAR",
    "https://rumble.com/user/NorthDakotaFairytales",
    "https://www.dailymotion.com/northdakotafairytales",
    "https://www.dailymotion.com/northdakotafairytalesspanish",
    "https://www.dailymotion.com/northdakotafairytalesarabic",
    "https://www.dailymotion.com/northdakotafairytalesfrench",
    "https://music.apple.com/gb/artist/north-dakota-fairytales/1831801227",
    "https://music.apple.com/us/artist/north-dakota-fairytales-spanish/1831890906",
    "https://music.apple.com/ie/artist/north-dakota-fairytales-arabic/1832063964",
    "https://music.apple.com/us/artist/north-dakota-fairytales-french/1832369557",
    "https://open.spotify.com/artist/55XaHR09Tq6FgSgSa1datk",
    "https://www.pinterest.com/northdakotafairytales/"
];


// ... твои импорты и другие константы (l10n и т.д.)

const domain = "https://northdakotafairytales.org";
const currentPath = Astro.url.pathname;
const segments = currentPath.split('/').filter(Boolean);


const formatName = (str: string) =>
    str
        .replace(/-/g, ' ')
        .replace(/\b\w/g, c => c.toUpperCase());

const breadcrumbElements = [
{
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": `${domain}/`
    }
];

segments.forEach((segment, index) => {
    const path = segments.slice(0, index + 1).join('/');
    breadcrumbElements.push({
        "@type": "ListItem",
        "position": index + 2,
        "name": formatName(segment),
        "item": `${domain}/${path}/`
    });
    });

// Теперь собираем всё в один массив Graph
const schemaGraph = [
{
    "@type": "BreadcrumbList",
    "@id": `${domain}${currentPath}#breadcrumb`,
    "itemListElement": breadcrumbElements
    },

{
        "@type": "Organization",
        "@id": "https://northdakotafairytales.org/#organization",
        "name": "North Dakota Fairytales",
        "url": "https://northdakotafairytales.org/",
        "logo": {
            "@type": "ImageObject",
            "url": "https://northdakotafairytales.org/favicon.ico"
        },
        "sameAs": sameAsLinks,
        "description": siteDesc
},

    {
        "@type": "WebSite",
        "@id": "https://northdakotafairytales.org/#website",
        "url": "https://northdakotafairytales.org/",
        "name": "North Dakota Fairytales",
        "publisher": {
            "@id": "https://northdakotafairytales.org/#organization"
        },
        "inLanguage": lang
    },

    {
        "@type": "WebPage",
        "@id": canonicalURL.href + "#webpage",
        "url": canonicalURL.href,
        "name": siteTitle,
        "description": siteDesc,
        "inLanguage": lang,
        "isPartOf": {
            "@id": "https://northdakotafairytales.org/#website"
        },
        "breadcrumb": { "@id": `${domain}${currentPath}#breadcrumb` },
        "about": {
            "@id": "https://northdakotafairytales.org/#organization"
        }
    },

    {
        "@type": "Person",
        "@id": "https://northdakotafairytales.org/#person",
        "name": "Paul Brian Mashkovtsev",
        "url": `${domain}/${lang}/about_the_creator/`,
"jobTitle": "Author, Songwriter, Creator",
    "worksFor": {
    "@id": "https://northdakotafairytales.org/#organization"
},
"sameAs": sameAsLinks,
    "knowsAbout": currentL10n.tags
}
];
---

<script type="application/ld+json" is:inline>
    {JSON.stringify({
        "@context": "https://schema.org",
        "@graph": schemaGraph
    })}
</script>
